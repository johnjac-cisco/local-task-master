# Task Master Environment Configuration

# AI Provider Configuration

# OpenAI-compatible Endpoints (including local LLMs)
OPENAI_BASE_URL=https://api.openai.com/v1  # Change this for local endpoints (e.g., http://localhost:11434/v1)
OPENAI_API_KEY=your-api-key-here           # Use 'none' for local endpoints that don't require auth
OPENAI_MODEL=gpt-4                         # Model name for OpenAI or compatible endpoint
OPENAI_MAX_TOKENS=4000                     # Maximum tokens for responses
OPENAI_TEMPERATURE=0.7                     # Temperature for responses (0.0-1.0)

# Local LLM Configuration
USE_LOCAL_LLM=false                        # Set to 'true' to enable local LLM
LOCAL_LLM_BASE_URL=http://localhost:11434/v1  # Your local LLM endpoint
LOCAL_LLM_API_KEY=none                     # API key if required, 'none' if not
LOCAL_LLM_MODEL=mistral                    # Model name for your local LLM
LOCAL_LLM_MAX_TOKENS=4000                  # Maximum tokens for local LLM
LOCAL_LLM_TEMPERATURE=0.7                  # Temperature for local LLM (0.0-1.0)

# Legacy/Fallback Providers

# Anthropic Configuration (Legacy/Fallback)
ANTHROPIC_API_KEY=your-api-key-here        # Format: sk-ant-api03-...
MODEL=claude-3-7-sonnet-20250219           # Recommended models: claude-3-7-sonnet-20250219, claude-3-opus-20240229
MAX_TOKENS=64000                           # Maximum tokens for model responses
TEMPERATURE=0.2                            # Temperature for model responses (0.0-1.0)

# Perplexity Configuration (Legacy/Fallback)
PERPLEXITY_API_KEY=your-api-key-here       # Format: pplx-...
PERPLEXITY_MODEL=sonar-pro                 # Make sure you have access to sonar-pro

# Application Configuration
DEBUG=false                                # Enable debug logging (true/false)
LOG_LEVEL=info                             # Log level (debug, info, warn, error)
DEFAULT_SUBTASKS=5                         # Default number of subtasks when expanding
DEFAULT_PRIORITY=medium                    # Default priority for generated tasks (high, medium, low)
PROJECT_NAME=My Project                    # Project name for tasks.json metadata 